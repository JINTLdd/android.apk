<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:layoutDirection="rtl">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/card_bg"
        app:titleTextColor="@color/gold"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView style="@style/SectionLabel" android:text="@string/lbl_method"/>
            <Spinner android:id="@+id/spinner_method"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/spinner_bg"
                android:layout_marginBottom="16dp"/>

            <TextView style="@style/SectionLabel" android:text="@string/lbl_madhab"/>
            <Spinner android:id="@+id/spinner_madhab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/spinner_bg"
                android:layout_marginBottom="16dp"/>

            <TextView style="@style/SectionLabel" android:text="@string/lbl_adhan_voice"/>
            <Spinner android:id="@+id/spinner_adhan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/spinner_bg"
                android:layout_marginBottom="20dp"/>

            <Switch android:id="@+id/sw_adhan" style="@style/SettingSwitch"
                android:text="@string/sw_adhan"/>
            <Switch android:id="@+id/sw_morning" style="@style/SettingSwitch"
                android:text="@string/sw_morning"/>
            <Switch android:id="@+id/sw_evening" style="@style/SettingSwitch"
                android:text="@string/sw_evening"/>
            <Switch android:id="@+id/sw_vibrate" style="@style/SettingSwitch"
                android:text="@string/sw_vibrate"/>
            <Switch android:id="@+id/sw_dark" style="@style/SettingSwitch"
                android:text="@string/sw_dark"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginVertical="16dp"/>

            <TextView style="@style/SectionLabel" android:text="@string/lbl_reliability"/>

            <TextView android:id="@+id/lbl_exact_alarm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:paddingBottom="6dp"
                android:text="@string/exact_alarm_needed"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_exact_alarm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="@string/btn_exact_alarm"
                app:cornerRadius="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_battery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_battery"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:text="@string/btn_save"
        android:textColor="@color/bg_primary"
        android:backgroundTint="@color/gold"
        app:cornerRadius="14dp"/>
</LinearLayout>
