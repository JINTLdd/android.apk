ْ تَعْرُضُوا عَلَيْهَا شَيْئاً، وَأَطْفِئُوا مَصَابِيحَكُمْ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 2,\n    title: \"رد كيد مردة الشياطين\",\n    text: \"«أَعُوذُ بِكَلِمَاتِ اللَّهِ التَّامَّاتِ الَّتِي لاَ يُجَاوِزُهُنَّ بَرٌّ وَلاَ فَاجِرٌ: مِنْ شَرِّ مَا خَلَقَ، وَبَرَأَ وَذَرَأَ، وَمِنْ شَرِّ مَا يَنْزِلُ مِنَ السَّمَاءِ، وَمِنْ شَرِّ مَا يَعْرُجُ فيهَا، وَمِنْ شَرِّ مَا ذَرَأَ فِي الْأَرْضِ، وَمِنْ شَرِّ مَا يَخْرُجُ مِنْهَا، وَمِنْ شَرِّ فِتَنِ اللَّيْلِ وَالنَّهَارِ، وَمِنْ شَرِّ كُلِّ طَارِقٍ إِلاَّ طَارِقاً يَطْرُقُ بِخَيْرٍ يَا رَحْمَنُ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 3,\n    title: \"تعويذ الأولاد\",\n    text: \"كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يُعَوِّذُ الحَسَنَ وَالحُسَيْنَ رضي الله عنهما: «أُعِيذُكُمَا بِكَلِمَاتِ اللَّهِ التَّامَّةِ مِنْ كُلِّ شَيْطَانٍ وَهَامَّةٍ، وَمِنْ كُلِّ عَيْنٍ لاَمَّةٍ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 4,\n    title: \"عند الذبح أو النحر\",\n    text: \"«بِسْمِ اللَّهِ وَاللَّهُ أَكْبَرُ، اللَّهُمَّ مِنْكَ وَلَكَ، اللَّهُمَّ تَقَبَّلْ مِنِّي»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 5,\n    title: \"عند الفزع\",\n    text: \"«لاَ إِلَهَ إِلاَّ اللَّهُ!»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 6,\n    title: \"خشية إصابة العين\",\n    text: \"«إِذَا رَأَى أَحَدُكُمْ مِنْ أَخِيهِ، أَوْ مِنْ نَفْسِهِ، أَوْ مِنْ مَالِهِ مَا يُعْجِبُهُ فَلْيَدْعُ لَهُ بِالْبَرَكَةِ فَإِنَّ الْعَيْنَ حَقٌّ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 7,\n    title: \"من أحس وجعاً في جسده\",\n    text: \"ضَعْ يَدَكَ عَلَى الَّذِي تَأَلَّمَ مِنْ جَسَدِكَ وَقُلْ: بِسْمِ اللَّهِ (ثلاثاً)، وَقُلْ سَبْعَ مَرَّاتٍ: أَعُوذُ بِاللَّهِ وَقُدْرَتِهِ مِنْ شَرِّ مَا أَجِدُ وَأُحَاذِرُ\",\n    count: 7,\n    audioUrl: \"\"\n  }, {\n    id: 8,\n    title: \"دعاء التعجب والأمر السار\",\n    text: \"«سُبْحَانَ اللَّهِ!»، «اللَّهُ أَكْبَرُ!»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 9,\n    title: \"إذا أتاه أمر يسره أو يكرهه\",\n    text: \"إذا أَتَاهُ الْأَمْرُ يَسُرُّهُ قَالَ: «الْحَمْدُ لِلَّهِ الَّذِي بِنِعْمَتِهِ تَتِمُّ الصَّالِحَاتُ» وَإِذَا أَتَاهُ الْأَمْرُ يَكْرَهُهُ قَالَ: «الْحَمْدُ لِلَّهِ عَلَى كُلِّ حَالٍ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 10,\n    title: \"نباح الكلاب بالليل\",\n    text: \"«إِذَا سَمِعْتُمْ نُبَاحَ الْكِلاَبِ وَنَهِيقَ الْحَمِيرِ بِاللَّيْلِ فَتَعَوَّذُوا بِاللَّهِ مِنْهُنَّ؛ فَإِنَّهُنَّ يَرَيْنَ مَا لاَ تَرَوْنَ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 11,\n    title: \"صياح الديك ونهيق الحمار\",\n    text: \"«إِذَا سَمِعْتُمْ صِيَاحَ الدِّيَكَةِ فَاسْأَلُوا اللَّهَ مِنْ فَضْلِهِ؛ فَإِنَّهَا رَأَتْ مَلَكاً وَإِذَا سَمِعْتُمْ نَهِيقَ الْحِمَارِ فَتَعَوَّذُوا بِاللَّهِ مِنَ الشَّيْطَانِ؛ فَإِنَّهُ رَأَى شَيْطَاناً»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 12,\n    title: \"إذا زُكِّي المسلم\",\n    text: \"«اللَّهُمَّ لاَ تُؤَاخِذْنِي بِمَا يَقُولُونَ، وَاغْفِرْ لِي مَا لاَ يَعْلَمُونَ، وَاجْعَلْنِي خَيْراً مِمَّا يَظُنُّونَ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 13,\n    title: \"إذا مدح المسلمَ المسلمُ\",\n    text: \"«إِذَا كَانَ أَحَدُكُمْ مَادِحاً صَاحِبَهُ لاَ مَحَالَةَ فَلْيَقُلْ: أَحْسِبُ فُلاَناً وَاللَّهُ حَسِيبُهُ، وَلاَ أُزَكِّي عَلَى اللَّهِ أَحَداً، أَحْسِبُهُ – إِنْ كَانَ يَعْلَمُ ذَاكَ – كَذَا وَكَذَا»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 14,\n    title: \"الدعاء لمن سببتَه\",\n    text: \"«اللَّهُمَّ فَأَيُّمَا مُؤْمِنٍ سَبَبْتُهُ فَاجْعَلْ ذَلِكَ لَهُ قُرْبَةً إِلَيْكَ يَوْمَ الْقِيَامَةِ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 15,\n    title: \"إفشاء السلام\",\n    text: \"«لاَ تَدْخُلُوا الْجَنَّةَ حَتَّى تُؤْمِنُوا، وَلاَ تُؤْمِنُوا حَتَّى تَحَابُّوا، أَوَلاَ أَدُلُّكُمْ عَلَى شَيْءٍ إِذَا فَعَلْتُمُوهُ تَحَابَبْتُمْ، أَفْشُوا السَّلاَمَ بَيْنَكُمْ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 16,\n    title: \"وسوسة في الإيمان\",\n    text: \"يَسْتَعِيذُ بِاللَّهِ وَيَنْتَهِي عَمَّا شَكَّ فِيهِ، وَيَقُولُ: «آمَنْتُ بِاللَّهِ وَرُسُلِهِ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 17,\n    title: \"ذكر الرجوع من السفر\",\n    text: \"يُكَبِّرُ عَلَى كُلِّ شَرَفٍ ثَلاَثَ تَكْبِيرَاتٍ ثُمَّ يَقُولُ: «لاَ إِلَهَ إِلاَّ اللَّهُ وَحْدَهُ لاَ شَرِيكَ لَهُ، لَهُ الْمُلْكُ، وَلَهُ الْحَمْدُ، وَهُوَ عَلَى كُلِّ شَيْءٍ قَدِيرٌ، آيِبُونَ، تَائِبُونَ، عَابِدُونَ، لِرَبِّنَا حَامِدُونَ، صَدَقَ اللَّهُ وَعْدَهُ، وَنَصَرَ عَبْدَهُ، وَهَزَمَ الْأَحْزَابَ وَحْدَهُ»\",\n    count: 1,\n    audioUrl: \"\"\n  }];\n\n  // Hajj-specific adhkar\n  const hajjAdhkar = [{\n    id: 1,\n    title: \"التلبية في الحج والعمرة\",\n    text: \"«لَبَّيْكَ اللَّهُمَّ لَبَّيْكَ، لَبَّيْكَ لاَ شَرِيكَ لَكَ لَبَّيْكَ، إِنَّ الْحَمْدَ، وَالنِّعْمَةَ، لَكَ وَالْمُلْكَ، لاَ شَرِيكَ لَكَ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 2,\n    title: \"التكبير عند الحجر الأسود\",\n    text: \"«طَافَ النَّبيُّ صلى الله عليه وسلم بِالْبَيْتِ عَلَى بَعِيرٍ كُلَّمَا أَتَى الرُّكْنَ أَشَارَ إِلَيْهِ بِشَيْءٍ عِنْدَهُ وَكَبَّرَ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 3,\n    title: \"بين الركن اليماني والحجر الأسود\",\n    text: \"«﴿رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً وَفِي الْآخِرَةِ حَسَنَةً وَقِنَا عَذَابَ النَّارِ﴾»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 4,\n    title: \"دعاء الصفا والمروة\",\n    text: \"«لاَ إِلَهَ إِلاَّ اللَّهُ وَحْدَهُ لاَ شَرِيكَ لَهُ، لَهُ الْمُلْكُ وَلَهُ الْحَمْدُ وَهُوَ عَلَى كُلِّ شَيْءٍ قَدِيرٌ، لاَ إِلَهَ إِلاَّ اللَّهُ وَحْدَهُ، أَنْجَزَ وَعْدَهُ، وَنَصَرَ عَبْدَهُ، وَهَزَمَ الْأَحْزَابَ وَحْدَهُ» (ثلاث مرات)\",\n    count: 3,\n    audioUrl: \"\"\n  }, {\n    id: 5,\n    title: \"دعاء يوم عرفة\",\n    text: \"«خَيْرُ الدُّعَاءِ دُعَاءُ يَوْمِ عَرَفَةَ، وَخَيْرُ مَا قُلْتُ أَنَا وَالنَّبيُّونَ مِنْ قَبْلِي: لاَ إِلَهَ إِلاَّ اللَّهُ وَحْدَهُ لاَ شَرِيكَ لَهُ، لَهُ الْمُلْكُ وَلَهُ الْحَمْدُ وَهُوَ عَلَى كُلِّ شَيْءٍ قَدِيرٌ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 6,\n    title: \"عند المشعر الحرام\",\n    text: \"يَسْتَقْبِلُ الْقِبْلَةَ فَيَدْعُو، وَيُكَبِّرُ، وَيُهَلِّلُ، وَيُوَحِّدُ اللَّهَ حَتَّى يُسْفِرَ جِدّاً ثُمَّ يَدْفَعُ قَبْلَ أَنْ تَطْلُعَ الشَّمْسُ\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 7,\n    title: \"التكبير عند رمي الجمار\",\n    text: \"يُكَبِّرُ كُلَّمَا رَمَى بِحَصَاةٍ عِنْدَ الْجِمَارِ الثَّلاَثِ، ثُمَّ يَتَقَدَّمُ، وَيَقِفُ يَدْعُو مُسْتَقْبِلَ الْقِبْلَةِ، رَافِعاً يَدَيْهِ بَعْدَ الْجَمْرَةِ الْأُولَى وَالثَّانِيَةِ. أَمَّا جَمْرَةُ الْعَقَبَةِ فَيَرْمِيهَا وَيُكَبِّرُ عِنْدَ كُلِّ حَصَاةٍ وَيَنْصَرِفُ وَلاَ يَقِفُ عِنْدَهَا\",\n    count: 1,\n    audioUrl: \"\"\n  }];\n\n  // Salat on the Prophet ﷺ - virtues\n  const salatNabiAdhkar = [{\n    id: 1,\n    title: \"من صلى عليّ صلاة\",\n    text: \"قَالَ النَّبِيُّ صلى الله عليه وسلم: «مَنْ صَلَّى عَلَيَّ صَلاَةً صَلَّى اللَّهُ عَلَيْهِ بِهَا عَشْراً»\",\n    count: 10,\n    audioUrl: \"\"\n  }, {\n    id: 2,\n    title: \"صلاتكم تبلغني\",\n    text: \"«لاَ تَجْعَلُوا قَبْرِي عِيداً وَصَلُّوا عَلَيَّ؛ فَإِنَّ صَلاَتَكُمْ تَبْلُغُنِي حَيْثُ كُنْتُمْ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 3,\n    title: \"البخيل من لم يصلِّ عليّ\",\n    text: \"«الْبَخِيلُ مَنْ ذُكِرْتُ عِنْدَهُ فَلَمْ يُصَلِّ عَلَيَّ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 4,\n    title: \"ملائكة يبلغون السلام\",\n    text: \"«إِنَّ لِلَّهِ مَلاَئِكَةً سَيَّاحِينَ فِي الْأَرْضِ يُبَلِّغُونِي مِنْ أُمَّتِي السَّلاَمَ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 5,\n    title: \"رد السلام على النبي ﷺ\",\n    text: \"«مَا مِنْ أَحَدٍ يُسَلِّمُ عَلَيَّ إِلاَّ رَدَّ اللَّهُ عَلَيَّ رُوحِي حَتَّى أَرُدَّ عَلَيْهِ السَّلاَمَ»\",\n    count: 1,\n    audioUrl: \"\"\n  }];\n\n  // Expanded sleep adhkar - replace existing\n  const sleepAdhkarExpanded = [{\n    id: 1,\n    title: \"المعوذات قبل النوم (ثلاثاً)\",\n    text: \"يَجْمَعُ كَفَّيْهِ ثُمَّ يَنْفُثُ فِيهِمَا فَيَقْرَأُ:\\nبِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ ﴿قُلْ هُوَ اللَّهُ أَحَدٌ * اللَّهُ الصَّمَدُ * لَمْ يَلِدْ وَلَمْ يُولَدْ * وَلَمْ يَكُن لَّهُ كُفُواً أَحَدٌ﴾\\n﴿قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ...﴾\\n﴿قُلْ أَعُوذُ بِرَبِّ النَّاسِ...﴾\\nثُمَّ يَمْسَحُ بِهِمَا مَا اسْتَطَاعَ مِنْ جَسَدِهِ يَبْدَأُ بِهِمَا عَلَى رَأْسِهِ وَوَجْهِهِ وَمَا أَقْبَلَ مِنْ جَسَدِهِ (يفعل ذلك ثلاث مرات)\",\n    count: 3,\n    audioUrl: \"http://www.hisnmuslim.com/audio/ar/ar_7esn_AlMoslem_by_Doors_029.mp3\"\n  }, {\n    id: 2,\n    title: \"آية الكرسي\",\n    text: \"﴿اللَّهُ لاَ إِلَهَ إِلاَّ هُوَ الْحَيُّ الْقَيُّومُ لاَ تَأْخُذُهُ سِنَةٌ وَلاَ نَوْمٌ لَّهُ مَا فِي السَّمَوَاتِ وَمَا فِي الأَرْضِ مَن ذَا الَّذِي يَشْفَعُ عِنْدَهُ إِلاَّ بِإِذْنِهِ يَعْلَمُ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ وَلاَ يُحِيطُونَ بِشَيْءٍ مِّنْ عِلْمِهِ إِلاَّ بِمَا شَاء وَسِعَ كُرْسِيُّهُ السَّمَوَاتِ وَالأَرْضَ وَلاَ يَؤُودُهُ حِفْظُهُمَا وَهُوَ الْعَلِيُّ الْعَظِيمُ﴾\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 3,\n    title: \"آخر آيتين من البقرة\",\n    text: \"﴿آمَنَ الرَّسُولُ بِمَا أُنزِلَ إِلَيْهِ مِن رَّبِّهِ وَالْمُؤْمِنُونَ كُلٌّ آمَنَ بِاللَّهِ وَمَلآئِكَتِهِ وَكُتُبِهِ وَرُسُلِهِ لاَ نُفَرِّقُ بَيْنَ أَحَدٍ مِّن رُّسُلِهِ وَقَالُواْ سَمِعْنَا وَأَطَعْنَا غُفْرَانَكَ رَبَّنَا وَإِلَيْكَ الْمَصِيرُ * لاَ يُكَلِّفُ اللَّهُ نَفْساً إِلاَّ وُسْعَهَا...﴾\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 4,\n    title: \"باسمك ربي وضعت جنبي\",\n    text: \"«بِاسْمِكَ رَبِّي وَضَعْتُ جَنْبِي، وَبِكَ أَرْفَعُهُ، فَإِنْ أَمْسَكْتَ نَفْسِي فَارْحَمْهَا، وَإِنْ أَرْسَلْتَهَا فَاحْفَظْهَا، بِمَا تَحْفَظُ بِهِ عِبَادَكَ الصَّالِحِينَ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 5,\n    title: \"اللهم إنك خلقت نفسي\",\n    text: \"«اللَّهُمَّ إِنَّكَ خَلَقْتَ نَفْسِي وَأَنْتَ تَوَفَّاهَا، لَكَ مَمَاتُهَا وَمَحْيَاهَا، إِنْ أَحْيَيْتَهَا فَاحْفَظْهَا، وَإِنْ أَمَتَّهَا فَاغْفِرْ لَهَا. اللَّهُمَّ إِنِّي أَسْأَلُكَ الْعَافِيَةَ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 6,\n    title: \"اللهم قني عذابك\",\n    text: \"«اللَّهُمَّ قِنِي عَذَابَكَ يَوْمَ تَبْعَثُ عِبَادَكَ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 7,\n    title: \"باسمك اللهم أموت وأحيا\",\n    text: \"«بِاسْمِكَ اللَّهُمَّ أَمُوتُ وَأَحْيَا»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 8,\n    title: \"تسبيح فاطمة (33/33/34)\",\n    text: \"سُبْحَانَ اللَّهِ (ثلاثاً وثلاثين)، الْحَمْدُ لِلَّهِ (ثلاثاً وثلاثين)، اللَّهُ أَكْبَرُ (أربعاً وثلاثين)\",\n    count: 100,\n    audioUrl: \"\"\n  }, {\n    id: 9,\n    title: \"اللهم رب السماوات السبع\",\n    text: \"«اللَّهُمَّ رَبَّ السَّمَوَاتِ السَّبْعِ وَرَبَّ الأَرْضِ، وَرَبَّ الْعَرْشِ الْعَظِيمِ، رَبَّنَا وَرَبَّ كُلِّ شَيْءٍ، فَالِقَ الْحَبِّ وَالنَّوَى، وَمُنْزِلَ التَّوْرَاةِ وَالْإِنْجِيلِ، وَالْفُرْقَانِ، أَعُوذُ بِكَ مِنْ شَرِّ كُلِّ شَيْءٍ أَنْتَ آخِذٌ بِنَاصِيَتِهِ. اللَّهُمَّ أَنْتَ الأَوَّلُ فَلَيْسَ قَبْلَكَ شَيْءٌ، وَأَنْتَ الآخِرُ فَلَيْسَ بَعْدَكَ شَيْءٌ، وَأَنْتَ الظَّاهِرُ فَلَيْسَ فَوْقَكَ شَيْءٌ، وَأَنْتَ الْبَاطِنُ فَلَيْسَ دُونَكَ شَيْءٌ، اقْضِ عَنَّا الدَّيْنَ وَأَغْنِنَا مِنَ الْفَقْرِ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 10,\n    title: \"الحمد لله الذي أطعمنا\",\n    text: \"«الْحَمْدُ لِلَّهِ الَّذِي أَطْعَمَنَا وَسَقَانَا، وَكَفَانَا، وَآوَانَا، فَكَمْ مِمَّنْ لاَ كَافِيَ لَهُ وَلاَ مُؤْوِيَ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 11,\n    title: \"اللهم عالم الغيب\",\n    text: \"«اللَّهُمَّ عَالِمَ الغَيْبِ وَالشَّهَادَةِ فَاطِرَ السَّمَوَاتِ وَالْأَرْضِ، رَبَّ كُلِّ شَيْءٍ وَمَلِيكَهُ، أَشْهَدُ أَنْ لاَ إِلَهَ إِلاَّ أَنْتَ، أَعُوذُ بِكَ مِنْ شَرِّ نَفْسِي، وَمِنْ شَرِّ الشَّيْطَانِ وَشِرْكِهِ، وَأَنْ أَقْتَرِفَ عَلَى نَفْسِي سُوءاً، أَوْ أَجُرَّهُ إِلَى مُسْلِمٍ»\",\n    count: 1,\n    audioUrl: \"\"\n  }, {\n    id: 12,\n    title: \"اللهم أسلمت نفسي إليك\",\n    text: \"«اللَّهُمَّ أَسْلَمْتُ نَفْسِي إِلَيْكَ، وَفَوَّضْتُ أَمْرِي إِلَيْكَ، وَوَجَّهْتُ وَجْهِي إِلَيْكَ، وَأَلْجَأْتُ ظَهْرِي إِلَيْكَ، رَغْبَةً وَرَهْبَةً إِلَيْكَ، لاَ مَلْجَأَ وَلاَ مَنْجَا مِنْكَ إِلاَّ إِلَيْكَ، آمَنْتُ بِكِتَابِكَ الَّذِي أَنْزَلْتَ، وَبِنَبِيِّكَ الَّذِي أَرْسَلْتَ»\",\n    count: 1,\n    audioUrl